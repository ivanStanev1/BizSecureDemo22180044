<!doctype html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - BizSecureDemo22180044</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">BizSecureDemo22180044</a>

            <div class="d-flex gap-2">
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <span class="navbar-text me-2 text-info">Здравей, @User.Identity.Name</span>
                    <a class="btn btn-outline-light btn-sm" asp-controller="Home" asp-action="Index">Начало</a>
                    <a class="btn btn-danger btn-sm" asp-controller="Account" asp-action="Logout">Изход</a>
                }
                else
                {
                    <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Вход</a>
                    <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Register">Регистрация</a>
                }
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="container text-center text-muted mt-5">
        <p>&copy; 2026 - Проект на ФН: 22180044</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>