@model BizSecureDemo22180044.Models.Order

@{
    ViewData["Title"] = "Нова поръчка";
}

<div class="container mt-4">
    <h2>➕ Създай нова поръчка</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div class="form-group mb-3">
                    <label class="control-label">Заглавие (Title)</label>
                    <input asp-for="Title" class="form-control" placeholder="Въведи заглавие..." />
                </div>
                <div class="form-group mb-3">
                    <label class="control-label">Сума (Amount)</label>
                    <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                </div>
                <div class="form-group">
                    <button type="submit" class="btn btn-success">Запази поръчката</button>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Отказ</a>
                </div>
            </form>
        </div>
    </div>
</div>